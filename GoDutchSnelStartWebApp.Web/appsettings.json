{
  "ConnectionStrings": {
    "DefaultConnection": ""
  },
  "GoDutchAutoSync": {
    "Enabled": true,
    "IntervalMinutes": 15,
    "OverlapSeconds": 120
  },
  "MyPosAutoSync": {
    "Enabled": true,
    "IntervalMinutes": 60,
    "LookbackHours": 48
  },
  "SnelStartImportRetry": {
    "Enabled": true,
    "MaxAttempts": 3,
    "InitialDelayMilliseconds": 1000
  },
  "GoDutchApiRetry": {
    "Enabled": true,
    "MaxAttempts": 4,
    "InitialDelayMilliseconds": 1500,
    "MaxDelayMilliseconds": 15000,
    "JitterMilliseconds": 500
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "GoDutchSnelStartWebApp": "Debug"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/log-.txt",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 14,
          "shared": true,
          "flushToDiskInterval": "00:00:01"
        }
      }
    ],
    "Enrich": [ "FromLogContext" ]
  },
  "AllowedHosts": "*"
}