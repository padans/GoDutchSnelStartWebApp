@page "/mypos/auto-sync"
@rendermode @(new InteractiveServerRenderMode(prerender: false))

@using GoDutchSnelStartWebApp.Portal.Models.MyPos

@inject GoDutchSnelStartWebApp.Portal.Api.Interfaces.IBackendApiClient BackendApiClient
@inject ILogger<MyPosAutoSync> Logger

<PageTitle>myPOS auto-sync</PageTitle>

<h1 class="mb-1">myPOS auto-sync</h1>
<p class="text-muted mb-4">
    Stel de synchronisatiemethode in: een rollend terugkijkvenster of een vaste afgesloten kalenderperiode.
</p>

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger" role="alert">@errorMessage</div>
}

@if (!string.IsNullOrWhiteSpace(successMessage))
{
    <div class="alert alert-success" role="alert">@successMessage</div>
}

@if (isLoading)
{
    <p class="text-muted">Instellingen laden...</p>
}
else if (settings is not null)
{
    <div class="card mb-3">
        <div class="card-header fw-bold">Instellingen</div>
        <div class="card-body">

            <div class="row g-3 mb-3 align-items-end">
                <div class="col-md-3">
                    <div class="form-check mt-2">
                        <input class="form-check-input" type="checkbox" id="enabled" @bind="settings.Enabled" />
                        <label class="form-check-label" for="enabled">Auto-sync ingeschakeld</label>
                    </div>
                </div>

                <div class="col-md-3">
                    <label class="form-label">Interval (minuten)</label>
                    <input type="number" class="form-control" min="1" max="1440" @bind="settings.IntervalMinutes" />
                    <div class="form-text">Hoe vaak de auto-sync wordt gecontroleerd.</div>
                </div>
            </div>

            <hr />
            <h6 class="mb-3">Synchronisatiemethode</h6>

            <div class="row g-3 mb-3">
                <div class="col-12">
                    <div class="btn-group" role="group">
                        <input type="radio" class="btn-check" name="syncmode" id="modeLookback"
                               checked="@(settings.SyncMode == "Lookback")"
                               @onchange="SetModeLookback" />
                        <label class="btn btn-outline-primary" for="modeLookback">
                            Terugkijkvenster (uren)
                        </label>

                        <input type="radio" class="btn-check" name="syncmode" id="modePeriod"
                               checked="@(settings.SyncMode == "Period")"
                               @onchange="SetModePeriod" />
                        <label class="btn btn-outline-primary" for="modePeriod">
                            Kalenderperiode
                        </label>
                    </div>
                </div>
            </div>

            @if (settings.SyncMode == "Lookback")
            {
                <div class="row g-3">
                    <div class="col-md-3">
                        <label class="form-label">Terugkijkvenster (uren)</label>
                        <input type="number" class="form-control" min="1" max="720" @bind="settings.LookbackHours" />
                        <div class="form-text">Hoeveel uur terug per importronde (rollend venster).</div>
                    </div>
                </div>
                <div class="alert alert-info mt-3 mb-0">
                    <strong>Terugkijkvenster:</strong> bij elke ronde worden transacties van de afgelopen
                    <strong>@settings.LookbackHours uur</strong> opgehaald en verwerkt.
                    Geschikt voor realtime verwerking van pintransacties.
                </div>
            }
            else
            {
                <div class="row g-3">
                    <div class="col-md-4">
                        <label class="form-label">Periode</label>
                        <select class="form-select" @bind="settings.PeriodType">
                            <option value="Day">Dag (gisteren)</option>
                            <option value="Week">Week (vorige week ma–zo)</option>
                            <option value="Month">Maand (vorige kalendermaand)</option>
                            <option value="Quarter">Kwartaal (vorig kwartaal)</option>
                            <option value="Year">Jaar (vorig kalenderjaar)</option>
                        </select>
                        <div class="form-text">Altijd de laatste <em>afgesloten</em> periode in NL-tijdzone.</div>
                    </div>
                </div>
                <div class="alert alert-info mt-3 mb-0">
                    <strong>Kalenderperiode:</strong> bij elke ronde worden transacties van de
                    <strong>@PeriodLabel(settings.PeriodType)</strong> gesommeerd per transactietype
                    en als één journaalpost naar SnelStart gestuurd.
                    Transacties die al eerder zijn geëxporteerd worden niet dubbel verwerkt.
                </div>
            }

            <div class="mt-4">
                <button type="button" class="btn btn-primary" @onclick="SaveSettingsAsync" disabled="@isSaving">
                    @(isSaving ? "Opslaan..." : "Opslaan")
                </button>
                <button type="button" class="btn btn-outline-secondary ms-2" @onclick="LoadSettingsAsync" disabled="@isSaving">
                    Annuleren
                </button>
            </div>
        </div>
    </div>

    <div class="card">
        <div class="card-header fw-bold">Handmatig uitvoeren</div>
        <div class="card-body">
            <p class="text-muted mb-3">
                Voer de auto-sync nu direct uit met de bovenstaande instellingen voor alle actieve myPOS-koppelingen.
            </p>
            <button type="button" class="btn btn-outline-primary" @onclick="RunSyncAsync" disabled="@isRunning">
                @(isRunning ? "Bezig met synchroniseren..." : "Nu uitvoeren")
            </button>
        </div>
    </div>
}

@code {
    private MyPosAutoSyncSettingsViewModel? settings;
    private bool isLoading;
    private bool isSaving;
    private bool isRunning;
    private string? errorMessage;
    private string? successMessage;

    protected override async Task OnInitializedAsync() => await LoadSettingsAsync();

    private async Task LoadSettingsAsync()
    {
        isLoading = true;
        errorMessage = null;
        successMessage = null;

        try
        {
            settings = await BackendApiClient.GetMyPosAutoSyncSettingsAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "myPOS auto-sync instellingen laden mislukt.");
            errorMessage = $"Instellingen laden mislukt: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task SaveSettingsAsync()
    {
        if (settings is null) return;

        errorMessage = null;
        successMessage = null;

        if (settings.IntervalMinutes < 1)
        {
            errorMessage = "Interval moet minimaal 1 minuut zijn.";
            return;
        }

        if (settings.SyncMode == "Lookback" && settings.LookbackHours < 1)
        {
            errorMessage = "Terugkijkvenster moet minimaal 1 uur zijn.";
            return;
        }

        isSaving = true;

        try
        {
            await BackendApiClient.UpdateMyPosAutoSyncSettingsAsync(settings);
            successMessage = "Instellingen opgeslagen. De background worker gebruikt de nieuwe instellingen bij de volgende cyclus.";
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "myPOS auto-sync instellingen opslaan mislukt.");
            errorMessage = $"Opslaan mislukt: {ex.Message}";
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task RunSyncAsync()
    {
        errorMessage = null;
        successMessage = null;
        isRunning = true;

        try
        {
            await BackendApiClient.TriggerMyPosAutoSyncAsync();
            successMessage = "myPOS auto-sync is uitgevoerd voor alle actieve koppelingen.";
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "myPOS auto-sync handmatig uitvoeren mislukt.");
            errorMessage = $"Auto-sync uitvoeren mislukt: {ex.Message}";
        }
        finally
        {
            isRunning = false;
        }
    }

    private void SetModeLookback(ChangeEventArgs _) { if (settings is not null) settings.SyncMode = "Lookback"; }
    private void SetModePeriod(ChangeEventArgs _)   { if (settings is not null) settings.SyncMode = "Period"; }

    private static string PeriodLabel(string periodType) => periodType switch
    {
        "Week"    => "vorige week (maandag t/m zondag)",
        "Month"   => "vorige kalendermaand",
        "Quarter" => "vorig kwartaal",
        "Year"    => "vorig kalenderjaar",
        _         => "gisteren (volledige dag)"
    };
}
