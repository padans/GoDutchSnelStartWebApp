@page "/mypos/auto-sync"
@rendermode @(new InteractiveServerRenderMode(prerender: false))

@using GoDutchSnelStartWebApp.Portal.Models.MyPos

@inject GoDutchSnelStartWebApp.Portal.Api.Interfaces.IBackendApiClient BackendApiClient
@inject ILogger<MyPosAutoSync> Logger

<PageTitle>myPOS auto-sync</PageTitle>

<h1 class="mb-1">myPOS auto-sync</h1>
<p class="text-muted mb-4">
    Kies de synchronisatiemethode en sla de instellingen op. De achtergrondtaak gebruikt deze bij de volgende cyclus.
</p>

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger" role="alert">@errorMessage</div>
}
@if (!string.IsNullOrWhiteSpace(successMessage))
{
    <div class="alert alert-success" role="alert">@successMessage</div>
}

@if (isLoading)
{
    <p class="text-muted">Instellingen laden...</p>
}
else if (settings is not null)
{
    <h5 class="mb-3">Synchronisatiemethode — klik op een optie om deze te activeren</h5>

    <div class="row g-3 mb-4">

        @* Kaart: Terugkijkvenster *@
        <div class="col-md-6">
            <div class="card h-100 mode-card @(IsLookback ? "mode-active" : "mode-inactive")"
                 @onclick="SelectLookback" style="cursor:pointer;">
                <div class="card-header d-flex justify-content-between align-items-center
                            @(IsLookback ? "bg-primary text-white" : "bg-light text-muted")">
                    <span class="fw-bold">⏱ Terugkijkvenster</span>
                    @if (IsLookback)
                    {
                        <span class="badge bg-success">Actief</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">Inactief — klik om te activeren</span>
                    }
                </div>
                <div class="card-body @(IsLookback ? "" : "text-muted")">
                    <p class="small mb-3">
                        Bij elke controle worden transacties van de afgelopen <strong>X uur</strong> opgehaald.
                        Geschikt voor realtime verwerking van pintransacties.
                    </p>

                    <div class="row g-3 mb-3" @onclick:stopPropagation="true">
                        <div class="col-sm-6">
                            <div class="form-check mt-1">
                                <input class="form-check-input" type="checkbox" id="enabled-lb" @bind="settings.Enabled" />
                                <label class="form-check-label fw-semibold" for="enabled-lb">Auto-sync ingeschakeld</label>
                            </div>
                        </div>
                        <div class="col-sm-6">
                            <label class="form-label @(!settings.Enabled ? "text-muted" : "")">Controle-interval (min.)</label>
                            <input type="number" class="form-control form-control-sm" min="1" max="1440"
                                   @bind="settings.IntervalMinutes"
                                   disabled="@(!settings.Enabled)" />
                            <div class="form-text">Hoe vaak de taak controleert.</div>
                        </div>
                    </div>

                    <label class="form-label">Terugkijkvenster (uren)</label>
                    <input type="number" class="form-control" min="1" max="720"
                           @bind="settings.LookbackHours"
                           disabled="@(!IsLookback)"
                           @onclick:stopPropagation="true" />
                    <div class="form-text">Hoeveel uur terug per importronde.</div>
                </div>
            </div>
        </div>

        @* Kaart: Kalenderperiode *@
        <div class="col-md-6">
            <div class="card h-100 mode-card @(IsPeriod ? "mode-active" : "mode-inactive")"
                 @onclick="SelectPeriod" style="cursor:pointer;">
                <div class="card-header d-flex justify-content-between align-items-center
                            @(IsPeriod ? "bg-primary text-white" : "bg-light text-muted")">
                    <span class="fw-bold">📅 Kalenderperiode</span>
                    @if (IsPeriod)
                    {
                        <span class="badge bg-success">Actief</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">Inactief — klik om te activeren</span>
                    }
                </div>
                <div class="card-body @(IsPeriod ? "" : "text-muted")">
                    <p class="small mb-3">
                        Transacties worden per afgesloten kalenderperiode gesommeerd per type
                        en als één journaalpost naar SnelStart gestuurd.
                    </p>

                    <div class="row g-3 mb-3" @onclick:stopPropagation="true">
                        <div class="col-sm-6">
                            <div class="form-check mt-1">
                                <input class="form-check-input" type="checkbox" id="enabled-pd" @bind="settings.Enabled" />
                                <label class="form-check-label fw-semibold" for="enabled-pd">Auto-sync ingeschakeld</label>
                            </div>
                        </div>
                        <div class="col-sm-6">
                            <label class="form-label @(!settings.Enabled ? "text-muted" : "")">Controle-interval (min.)</label>
                            <input type="number" class="form-control form-control-sm" min="1" max="1440"
                                   @bind="settings.IntervalMinutes"
                                   disabled="@(!settings.Enabled)" />
                            <div class="form-text">Hoe vaak de taak controleert.</div>
                        </div>
                    </div>

                    <label class="form-label">Periode</label>
                    <select class="form-select" @bind="settings.PeriodType"
                            disabled="@(!IsPeriod)"
                            @onclick:stopPropagation="true">
                        <option value="Day">Dag — gisteren (00:00–23:59)</option>
                        <option value="Week">Week — vorige week (ma t/m zo)</option>
                        <option value="Month">Maand — vorige kalendermaand</option>
                        <option value="Quarter">Kwartaal — vorig kwartaal</option>
                        <option value="Year">Jaar — vorig kalenderjaar</option>
                    </select>
                    <div class="form-text">Altijd de laatste <em>afgesloten</em> periode in NL-tijdzone.</div>
                </div>
            </div>
        </div>

    </div>

    <div class="mb-4">
        <button type="button" class="btn btn-primary" @onclick="SaveSettingsAsync" disabled="@isSaving">
            @(isSaving ? "Opslaan..." : "Opslaan")
        </button>
        <button type="button" class="btn btn-outline-secondary ms-2" @onclick="LoadSettingsAsync" disabled="@isSaving">
            Annuleren
        </button>
    </div>

    <div class="card">
        <div class="card-header fw-bold">Handmatig uitvoeren</div>
        <div class="card-body">
            <p class="text-muted mb-3">
                Voer de auto-sync nu direct uit met de bovenstaande instellingen voor alle actieve myPOS-koppelingen.
            </p>
            <button type="button" class="btn btn-outline-primary" @onclick="RunSyncAsync" disabled="@isRunning">
                @(isRunning ? "Bezig met synchroniseren..." : "Nu uitvoeren")
            </button>
        </div>
    </div>
}

<style>
    .mode-card {
        transition: box-shadow .15s ease, opacity .15s ease;
        border-width: 2px;
    }
    .mode-active {
        border-color: #0066CC !important;
        box-shadow: 0 0 0 3px rgba(0,102,204,.2);
        opacity: 1;
    }
    .mode-inactive {
        border-color: #dee2e6 !important;
        opacity: .65;
    }
    .mode-inactive:hover {
        opacity: .85;
        box-shadow: 0 0 0 2px rgba(0,102,204,.15);
    }
</style>

@code {
    private MyPosAutoSyncSettingsViewModel? settings;
    private bool isLoading;
    private bool isSaving;
    private bool isRunning;
    private string? errorMessage;
    private string? successMessage;

    private bool IsLookback => settings?.SyncMode == "Lookback";
    private bool IsPeriod   => settings?.SyncMode == "Period";

    protected override async Task OnInitializedAsync() => await LoadSettingsAsync();

    private void SelectLookback() { if (settings is not null) settings.SyncMode = "Lookback"; }
    private void SelectPeriod()   { if (settings is not null) settings.SyncMode = "Period"; }

    private async Task LoadSettingsAsync()
    {
        isLoading = true;
        errorMessage = null;
        successMessage = null;

        try
        {
            settings = await BackendApiClient.GetMyPosAutoSyncSettingsAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "myPOS auto-sync instellingen laden mislukt.");
            errorMessage = $"Instellingen laden mislukt: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task SaveSettingsAsync()
    {
        if (settings is null) return;

        errorMessage = null;
        successMessage = null;

        if (settings.IntervalMinutes < 1)
        {
            errorMessage = "Controle-interval moet minimaal 1 minuut zijn.";
            return;
        }

        if (IsLookback && settings.LookbackHours < 1)
        {
            errorMessage = "Terugkijkvenster moet minimaal 1 uur zijn.";
            return;
        }

        isSaving = true;

        try
        {
            await BackendApiClient.UpdateMyPosAutoSyncSettingsAsync(settings);
            successMessage = "Instellingen opgeslagen. De background worker gebruikt de nieuwe instellingen bij de volgende cyclus.";
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "myPOS auto-sync instellingen opslaan mislukt.");
            errorMessage = $"Opslaan mislukt: {ex.Message}";
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task RunSyncAsync()
    {
        errorMessage = null;
        successMessage = null;
        isRunning = true;

        try
        {
            await BackendApiClient.TriggerMyPosAutoSyncAsync();
            successMessage = "myPOS auto-sync is uitgevoerd voor alle actieve koppelingen.";
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "myPOS auto-sync handmatig uitvoeren mislukt.");
            errorMessage = $"Auto-sync uitvoeren mislukt: {ex.Message}";
        }
        finally
        {
            isRunning = false;
        }
    }
}
