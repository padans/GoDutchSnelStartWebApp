    private void OnPeriodModeChanged(ChangeEventArgs args)
    {
        periodMode = args.Value?.ToString() ?? "Manual";
        ApplySelectedPeriod();
    }

    private void OnSelectedPeriodDateChanged(ChangeEventArgs args)
    {
        if (DateTime.TryParse(args.Value?.ToString(), out var parsed))
        {
            selectedPeriodDate = parsed.Date;
            ApplySelectedPeriod();
        }
    }

    private void OnSelectedMonthChanged(ChangeEventArgs args)
    {
        if (int.TryParse(args.Value?.ToString(), out var month))
        {
            selectedMonth = Math.Clamp(month, 1, 12);
            ApplySelectedPeriod();
        }
    }

    private void OnSelectedQuarterChanged(ChangeEventArgs args)
    {
        if (int.TryParse(args.Value?.ToString(), out var quarter))
        {
            selectedQuarter = Math.Clamp(quarter, 1, 4);
            ApplySelectedPeriod();
        }
    }

    private void OnSelectedYearChanged(ChangeEventArgs args)
    {
        if (int.TryParse(args.Value?.ToString(), out var year))
        {
            selectedYear = year;
            ApplySelectedPeriod();
        }
    }

    private void ApplySelectedPeriod()
    {
        switch (periodMode)
        {
            case "Day":
                ApplyDayPeriod();
                break;

            case "Week":
                ApplyWeekPeriod();
                break;

            case "Month":
                ApplyMonthPeriod();
                break;

            case "Quarter":
                ApplyQuarterPeriod();
                break;

            case "Year":
                ApplyYearPeriod();
                break;

            default:
                break;
        }
    }

    private void ApplyDayPeriod()
    {
        var date = (selectedPeriodDate ?? DateTime.Today).Date;

        fromDate = date;
        fromTime = new TimeOnly(0, 0);

        toDate = date;
        toTime = new TimeOnly(23, 59);
    }

    private void ApplyWeekPeriod()
    {
        var date = (selectedPeriodDate ?? DateTime.Today).Date;

        var diff = ((int)date.DayOfWeek + 6) % 7;
        var monday = date.AddDays(-diff);
        var sunday = monday.AddDays(6);

        fromDate = monday;
        fromTime = new TimeOnly(0, 0);

        toDate = sunday;
        toTime = new TimeOnly(23, 59);
    }

    private void ApplyMonthPeriod()
    {
        var firstDay = new DateTime(selectedYear, selectedMonth, 1);
        var lastDay = firstDay.AddMonths(1).AddDays(-1);

        fromDate = firstDay;
        fromTime = new TimeOnly(0, 0);

        toDate = lastDay;
        toTime = new TimeOnly(23, 59);
    }

    private void ApplyQuarterPeriod()
    {
        var firstMonth = ((selectedQuarter - 1) * 3) + 1;
        var firstDay = new DateTime(selectedYear, firstMonth, 1);
        var lastDay = firstDay.AddMonths(3).AddDays(-1);

        fromDate = firstDay;
        fromTime = new TimeOnly(0, 0);

        toDate = lastDay;
        toTime = new TimeOnly(23, 59);
    }

    private void ApplyYearPeriod()
    {
        var firstDay = new DateTime(selectedYear, 1, 1);
        var lastDay = new DateTime(selectedYear, 12, 31);

        fromDate = firstDay;
        fromTime = new TimeOnly(0, 0);

        toDate = lastDay;
        toTime = new TimeOnly(23, 59);
    }

