    private async Task SetProgressAsync(
    int percentage,
    string message,
    string? detail = null,
    string? title = null)
    {
        progressPercentage = Math.Clamp(percentage, 0, 100);
        progressMessage = message;
        progressDetail = detail ?? string.Empty;

        if (!string.IsNullOrWhiteSpace(title))
        {
            progressTitle = title;
        }

        await InvokeAsync(StateHasChanged);

        // Klein moment zodat de UI zichtbaar kan verversen.
        await Task.Delay(75);
    }

    private void HideProgress()
    {
        showProgress = false;
        progressPercentage = 0;
        progressMessage = string.Empty;
        progressDetail = string.Empty;
    }

    private async Task RunVisualProgressUntilAsync(
    Func<Task> longRunningAction,
    int startPercentage,
    int maxPercentage,
    string message,
    string? detail = null)
    {
        var actionTask = longRunningAction();

        var currentPercentage = startPercentage;

        while (!actionTask.IsCompleted)
        {
            await SetProgressAsync(
                currentPercentage,
                message,
                detail);

            currentPercentage++;

            if (currentPercentage > maxPercentage)
            {
                currentPercentage = startPercentage;
            }

            await Task.Delay(500);
        }

        await actionTask;
    }

    private async Task<MyPosTransactionImportResultViewModel> ImportMyPosTransactionsInChunksAsync(
        Guid tenantMyPosConnectionId,
        DateTime fromUtc,
        DateTime toUtc,
        bool showBusy)
    {
        var totalFetched = 0;
        var totalInsertedOrUpdated = 0;
        var totalInserted = 0;
        var totalUpdated = 0;
        var totalSkipped = 0;
        var totalDuplicateInImport = 0;

        var periods = BuildMonthlyUtcPeriods(fromUtc, toUtc).ToList();
        var totalPeriods = periods.Count;

        for (var index = 0; index < totalPeriods; index++)
        {
            var period = periods[index];

            if (showBusy)
            {
                var percentage = 15 + (int)Math.Round(((double)index / totalPeriods) * 25);

                await SetProgressAsync(
                    percentage,
                    "myPOS transacties ophalen...",
                    $"Blok {index + 1} van {totalPeriods}: {period.FromUtc:dd-MM-yyyy HH:mm} t/m {period.ToUtc:dd-MM-yyyy HH:mm} UTC");
            }

            var result = await BackendApiClient.ImportMyPosTransactionsAsync(
                TenantId,
                tenantMyPosConnectionId,
                period.FromUtc,
                period.ToUtc);

            totalFetched += result.FetchedCount;
            totalInsertedOrUpdated += result.InsertedOrUpdatedCount;
            totalInserted += result.InsertedCount;
            totalUpdated += result.UpdatedCount;
            totalSkipped += result.SkippedCount;
            totalDuplicateInImport += result.DuplicateInImportCount;

            if (showBusy)
            {
                var percentage = 15 + (int)Math.Round(((double)(index + 1) / totalPeriods) * 25);

                await SetProgressAsync(
                    percentage,
                    "myPOS transacties opgehaald...",
                    $"Blok {index + 1} van {totalPeriods} klaar. Nieuw: {totalInserted}, bestaand/bijgewerkt: {totalUpdated}, niet toegevoegd: {totalSkipped}");
            }
        }

        return new MyPosTransactionImportResultViewModel
        {
            FetchedCount = totalFetched,
            InsertedOrUpdatedCount = totalInsertedOrUpdated,
            InsertedCount = totalInserted,
            UpdatedCount = totalUpdated,
            SkippedCount = totalSkipped,
            DuplicateInImportCount = totalDuplicateInImport,
            FromUtc = fromUtc,
            ToUtc = toUtc,
            Message = "myPOS download geslaagd en raw transacties verwerkt."
        };
    }

    private static IEnumerable<(DateTime FromUtc, DateTime ToUtc)> BuildMonthlyUtcPeriods(
    DateTime fromUtc,
    DateTime toUtc)
    {
        var currentFromUtc = fromUtc;

        while (currentFromUtc < toUtc)
        {
            var currentToUtc = currentFromUtc.AddMonths(1);

            if (currentToUtc > toUtc)
            {
                currentToUtc = toUtc;
            }

            yield return (currentFromUtc, currentToUtc);

            currentFromUtc = currentToUtc;
        }
    }

    private async Task ExportBatchToSnelStartAsync(MyPosExportBatchViewModel batch)
    {
        errorMessage = null;
        successMessage = null;

        if (batch is null || batch.Id == Guid.Empty)
        {
            errorMessage = "Geen geldige exportbatch geselecteerd.";
            return;
        }

        if (!batch.IsReadyForExport ||
            !string.Equals(batch.Status, "Ready", StringComparison.OrdinalIgnoreCase))
        {
            errorMessage = "Deze exportbatch is niet klaar voor export naar SnelStart.";
            return;
        }

        var confirmed = await JSRuntime.InvokeAsync<bool>(
            "confirm",
            $"Weet je zeker dat je deze myPOS exportbatch naar SnelStart wilt exporteren?\n\n" +
            $"Boekjaar: {batch.BookYear}\n" +
            $"Periode: {batch.PeriodFromLocalDate:dd-MM-yyyy} t/m {batch.PeriodToLocalDate:dd-MM-yyyy}\n" +
            $"Regels: {batch.LineCount}\n" +
            $"Totaal: {batch.TotalAmount:N2} {batch.Currency}");

        if (!confirmed)
        {
            return;
        }

        isExportingBatch = true;
        exportingBatchId = batch.Id;

        showProgress = true;
        progressTitle = "Exporteren naar SnelStart";

        try
        {
            await SetProgressAsync(
                10,
                "Export voorbereiden...",
                "De exportbatch wordt gecontroleerd.");

            await SetProgressAsync(
                35,
                "SnelStart bankboeking aanmaken...",
                "De volledige batch wordt als één bankboeking verzonden.");

            var result = await BackendApiClient.ExportMyPosBatchToSnelStartAsync(
                TenantId,
                batch.Id);

            await SetProgressAsync(
                85,
                "Exportstatus bijwerken...",
                result.Message);

            await LoadExportBatchesForCurrentPeriodAsync();

            await SetProgressAsync(
                100,
                "Klaar.",
                "De myPOS exportbatch is verwerkt.");

            if (result.Success)
            {
                successMessage =
                    $"myPOS exportbatch is naar SnelStart geëxporteerd. " +
                    $"Regels: {result.ExportedLineCount}/{result.LineCount}.";
            }
            else
            {
                errorMessage =
                    $"myPOS exportbatch is niet volledig geëxporteerd. " +
                    $"Melding: {result.Message}";
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(
                ex,
                "myPOS exportbatch naar SnelStart mislukt. BatchId: {BatchId}",
                batch.Id);

            errorMessage = $"myPOS exportbatch naar SnelStart mislukt: {ex.Message}";

            await LoadExportBatchesForCurrentPeriodAsync();
        }
        finally
        {
            await Task.Delay(400);
            HideProgress();

            isExportingBatch = false;
            exportingBatchId = null;
        }
    }
