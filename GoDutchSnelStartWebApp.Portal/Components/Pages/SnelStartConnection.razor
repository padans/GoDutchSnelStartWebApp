@page "/snelstart/connection"
@rendermode @(new InteractiveServerRenderMode(prerender: false))

@using GoDutchSnelStartWebApp.Portal.Configuration
@using GoDutchSnelStartWebApp.Portal.Models
@using Microsoft.Extensions.Options

@inject IBackendApiClient BackendApiClient
@inject IOptions<PortalTenantOptions> TenantOptions
@inject ILogger<SnelStartConnection> Logger

<PageTitle>SnelStart koppeling</PageTitle>

<h1 class="mb-1">SnelStart koppeling</h1>
<p class="text-muted mb-4">
    Beheer de SnelStart API-verbinding, administraties en de koppeling van bankaccounts per administratie.
</p>

@if (!string.IsNullOrWhiteSpace(pageError))
{
    <div class="alert alert-danger">@pageError</div>
}

@if (isLoading)
{
    <p class="text-muted">Gegevens laden...</p>
}
else
{
    @* ─── SECTIE 1: Globale API-verbinding ─── *@
    <div class="card mb-4">
        <div class="card-header d-flex justify-content-between align-items-center">
            <span><strong>Globale API-verbinding</strong> — gedeeld voor alle administraties</span>
            @if (connection is not null)
            {
                <span class="badge @(connection.IsActive ? "bg-success" : "bg-secondary")">
                    @(connection.IsActive ? "Actief" : "Inactief")
                </span>
            }
        </div>
        <div class="card-body">
            @if (!string.IsNullOrWhiteSpace(connSuccess))
            {
                <div class="alert alert-success py-2">@connSuccess</div>
            }
            @if (!string.IsNullOrWhiteSpace(connError))
            {
                <div class="alert alert-danger py-2">@connError</div>
            }

            @if (connection is null)
            {
                <div class="alert alert-warning mb-3">
                    Nog geen globale API-verbinding aangemaakt.
                </div>
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label">Auth URL</label>
                        <input class="form-control" @bind="createConn.AuthUrl" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">API Base URL</label>
                        <input class="form-control" @bind="createConn.ApiBaseUrl" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Subscription Key</label>
                        <input class="form-control" type="password" @bind="createConn.SubscriptionKey" autocomplete="off" />
                    </div>
                    <div class="col-12">
                        <button class="btn btn-primary" @onclick="CreateConnectionAsync" disabled="@isSavingConn">
                            @(isSavingConn ? "Aanmaken..." : "Verbinding aanmaken")
                        </button>
                    </div>
                </div>
            }
            else
            {
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label">Auth URL</label>
                        <input class="form-control" @bind="connection.AuthUrl" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">API Base URL</label>
                        <input class="form-control" @bind="connection.ApiBaseUrl" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Subscription Key</label>
                        <input class="form-control" type="password" @bind="connSubscriptionKey" autocomplete="off"
                               placeholder="@(connection.HasSubscriptionKey ? "Laat leeg om te behouden" : "Vul in")" />
                        <div class="form-text">Opgeslagen: @(connection.HasSubscriptionKey ? "Ja" : "Nee")</div>
                    </div>
                    <div class="col-md-3 d-flex align-items-end">
                        <div class="form-check mb-2">
                            <input class="form-check-input" type="checkbox" id="connActive" @bind="connection.IsActive" />
                            <label class="form-check-label" for="connActive">Actief</label>
                        </div>
                    </div>
                    <div class="col-12">
                        <button class="btn btn-primary" @onclick="SaveConnectionAsync" disabled="@isSavingConn">
                            @(isSavingConn ? "Opslaan..." : "Opslaan")
                        </button>
                        <button class="btn btn-outline-secondary ms-2" @onclick="LoadAsync" disabled="@isSavingConn">
                            Vernieuwen
                        </button>
                    </div>
                </div>
            }
        </div>
    </div>

    @* ─── SECTIE 2: Administraties ─── *@
    <div class="card mb-4">
        <div class="card-header d-flex justify-content-between align-items-center">
            <strong>SnelStart administraties</strong>
            <button class="btn btn-sm btn-outline-success" @onclick="ToggleNewAdmin">
                @(showNewAdmin ? "Annuleren" : "+ Nieuwe administratie")
            </button>
        </div>
        <div class="card-body">

            @if (!string.IsNullOrWhiteSpace(adminSuccess))
            {
                <div class="alert alert-success py-2">@adminSuccess</div>
            }
            @if (!string.IsNullOrWhiteSpace(adminError))
            {
                <div class="alert alert-danger py-2">@adminError</div>
            }

            @if (showNewAdmin)
            {
                <div class="border rounded p-3 mb-3 bg-light">
                    <h6 class="mb-3">Nieuwe administratie</h6>
                    <div class="row g-3">
                        <div class="col-md-5">
                            <label class="form-label">Naam</label>
                            <input class="form-control" @bind="newAdmin.Name" placeholder="bijv. Hoofdadministratie" />
                        </div>
                        <div class="col-md-5">
                            <label class="form-label">Client Key</label>
                            <input class="form-control" type="password" @bind="newAdmin.AdministrationClientKey" autocomplete="off" />
                        </div>
                        <div class="col-md-2 d-flex align-items-end">
                            <div class="form-check mb-2">
                                <input class="form-check-input" type="checkbox" id="newAdminActive" @bind="newAdmin.IsActive" />
                                <label class="form-check-label" for="newAdminActive">Actief</label>
                            </div>
                        </div>
                        <div class="col-12">
                            <button class="btn btn-success btn-sm" @onclick="CreateAdminAsync" disabled="@isSavingAdmin">
                                @(isSavingAdmin ? "Aanmaken..." : "Aanmaken")
                            </button>
                        </div>
                    </div>
                </div>
            }

            @if (administrations.Count == 0)
            {
                <div class="text-muted">Nog geen administraties aangemaakt.</div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-sm align-middle mb-0">
                        <thead>
                            <tr>
                                <th>Interne naam</th>
                                <th>SnelStart administratienaam</th>
                                <th class="text-center">Client key</th>
                                <th class="text-center">Actief</th>
                                <th>Aangemaakt</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var admin in administrations)
                            {
                                <tr>
                                    @if (editingAdminId == admin.Id)
                                    {
                                        <td>
                                            <input class="form-control form-control-sm" @bind="editAdmin!.Name"
                                                   placeholder="Interne naam" />
                                        </td>
                                        <td>
                                            <input class="form-control form-control-sm" @bind="editAdmin!.NameSnelStartAdministration"
                                                   placeholder="SnelStart administratienaam" />
                                        </td>
                                        <td>
                                            <input class="form-control form-control-sm" type="password"
                                                   @bind="editAdminClientKey"
                                                   placeholder="@(admin.HasClientKey ? "Laat leeg om te behouden" : "Vul in")"
                                                   autocomplete="off" />
                                        </td>
                                        <td class="text-center">
                                            <input type="checkbox" @bind="editAdmin!.IsActive" />
                                        </td>
                                        <td>@admin.CreatedUtc.ToString("dd-MM-yyyy")</td>
                                        <td class="text-end">
                                            <button class="btn btn-sm btn-primary me-1" @onclick="() => SaveAdminAsync(admin.Id)" disabled="@isSavingAdmin">
                                                @(isSavingAdmin ? "..." : "Opslaan")
                                            </button>
                                            <button class="btn btn-sm btn-outline-secondary" @onclick="CancelEditAdmin">
                                                Annuleren
                                            </button>
                                        </td>
                                    }
                                    else
                                    {
                                        <td><strong>@admin.Name</strong></td>
                                        <td>
                                            @if (!string.IsNullOrWhiteSpace(admin.NameSnelStartAdministration))
                                            {
                                                @admin.NameSnelStartAdministration
                                            }
                                            else
                                            {
                                                <span class="text-muted fst-italic">Niet ingesteld</span>
                                            }
                                        </td>
                                        <td class="text-center">
                                            @if (admin.HasClientKey)
                                            {
                                                <span class="badge bg-success">Ingesteld</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-warning text-dark">Ontbreekt</span>
                                            }
                                        </td>
                                        <td class="text-center">
                                            <span class="badge @(admin.IsActive ? "bg-success" : "bg-secondary")">
                                                @(admin.IsActive ? "Ja" : "Nee")
                                            </span>
                                        </td>
                                        <td>@admin.CreatedUtc.ToString("dd-MM-yyyy")</td>
                                        <td class="text-end">
                                            <button class="btn btn-sm btn-outline-primary" @onclick="() => StartEditAdmin(admin)">
                                                Bewerken
                                            </button>
                                        </td>
                                    }
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>

    @* ─── SECTIE 3: Bankaccounts & koppelingen ─── *@
    <div class="card">
        <div class="card-header">
            <strong>Bankaccounts &amp; SnelStart-koppelingen</strong>
        </div>
        <div class="card-body">

            @if (!string.IsNullOrWhiteSpace(linkSuccess))
            {
                <div class="alert alert-success py-2">@linkSuccess</div>
            }
            @if (!string.IsNullOrWhiteSpace(linkError))
            {
                <div class="alert alert-danger py-2">@linkError</div>
            }

            @if (bankAccountRows.Count == 0)
            {
                <div class="text-muted">Geen bankaccounts gevonden voor deze tenant.</div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-sm align-middle">
                        <thead>
                            <tr>
                                <th>IBAN</th>
                                <th>Naam</th>
                                <th>Administratie</th>
                                <th>Export formaat</th>
                                <th class="text-center">Auto-sync</th>
                                <th class="text-center">Interval (min)</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var row in bankAccountRows)
                            {
                                <tr class="@(!row.BankAccount.IsActive ? "text-muted" : "")">
                                    <td>@row.BankAccount.Iban</td>
                                    <td>@row.BankAccount.AccountName</td>
                                    <td style="min-width:200px">
                                        <select class="form-select form-select-sm"
                                                value="@FormatGuid(row.Link?.SnelStartAdministrationId)"
                                                @onchange="e => OnAdminChanged(row, e)">
                                            <option value="">-- Geen koppeling --</option>
                                            @foreach (var admin in administrations)
                                            {
                                                <option value="@admin.Id">@(admin.NameSnelStartAdministration ?? admin.Name)</option>
                                            }
                                        </select>
                                    </td>
                                    <td>
                                        <select class="form-select form-select-sm"
                                                value="@(row.Link?.ExportFormat ?? "Mt940")"
                                                @onchange="e => OnFormatChanged(row, e)">
                                            <option value="Mt940">MT940</option>
                                            <option value="Camt053">CAMT053</option>
                                        </select>
                                    </td>
                                    <td class="text-center">
                                        <input type="checkbox"
                                               checked="@(row.Link?.AutoSyncEnabled ?? true)"
                                               @onchange="e => OnAutoSyncChanged(row, e)" />
                                    </td>
                                    <td>
                                        <input class="form-control form-control-sm" type="number" style="width:80px"
                                               value="@(row.Link?.SyncIntervalMinutes ?? 15)"
                                               @onchange="e => OnIntervalChanged(row, e)" min="1" />
                                    </td>
                                    <td>
                                        <button class="btn btn-sm btn-primary"
                                                @onclick="() => SaveLinkAsync(row)"
                                                disabled="@row.IsSaving">
                                            @(row.IsSaving ? "..." : (row.Link is null ? "Koppelen" : "Opslaan"))
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                <div class="form-text mt-2">
                    Wijzigingen per rij opslaan met de knop rechts. Laat "Administratie" leeg om een koppeling te verwijderen of niet in te stellen.
                </div>
            }
        </div>
    </div>
}

@code {
    private Guid TenantId => TenantOptions.Value.TenantId;

    // Sectie 1
    private TenantSnelStartConnectionViewModel? connection;
    private CreateTenantSnelStartConnectionRequestViewModel createConn = new();
    private string? connSubscriptionKey;
    private bool isSavingConn;
    private string? connSuccess;
    private string? connError;

    // Sectie 2
    private List<SnelStartAdministrationViewModel> administrations = [];
    private bool showNewAdmin;
    private CreateSnelStartAdministrationRequestViewModel newAdmin = new();
    private Guid? editingAdminId;
    private UpdateSnelStartAdministrationRequestViewModel? editAdmin;
    private string? editAdminClientKey;
    private bool isSavingAdmin;
    private string? adminSuccess;
    private string? adminError;

    // Sectie 3
    private List<BankAccountRow> bankAccountRows = [];
    private string? linkSuccess;
    private string? linkError;

    private bool isLoading;
    private string? pageError;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        isLoading = true;
        pageError = null;
        connSuccess = null;
        adminSuccess = null;
        linkSuccess = null;

        try
        {
            var connTask    = BackendApiClient.GetTenantSnelStartConnectionAsync(TenantId);
            var adminsTask  = BackendApiClient.GetSnelStartAdministrationsByTenantAsync(TenantId);
            var accountsTask = BackendApiClient.GetBankAccountsAsync(TenantId);

            await Task.WhenAll(connTask, adminsTask, accountsTask);

            connection      = connTask.Result;
            administrations = adminsTask.Result.OrderBy(a => a.Name).ToList();
            connSubscriptionKey = null;

            var accounts = accountsTask.Result;
            var rows = new List<BankAccountRow>();

            foreach (var account in accounts.OrderBy(a => a.AccountName))
            {
                var link = await BackendApiClient.GetBankAccountSnelStartLinkByBankAccountIdAsync(account.Id);
                rows.Add(new BankAccountRow
                {
                    BankAccount         = account,
                    Link                = link,
                    PendingAdminId      = link?.SnelStartAdministrationId,
                    PendingFormat       = link?.ExportFormat ?? "Mt940",
                    PendingAutoSync     = link?.AutoSyncEnabled ?? true,
                    PendingInterval     = link?.SyncIntervalMinutes ?? 15
                });
            }

            bankAccountRows = rows;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "SnelStart koppeling laden mislukt.");
            pageError = $"Laden mislukt: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    // ── Sectie 1 ──────────────────────────────────────────────────────────

    private async Task CreateConnectionAsync()
    {
        connError = null;
        connSuccess = null;

        if (string.IsNullOrWhiteSpace(createConn.SubscriptionKey))
        {
            connError = "Subscription Key is verplicht.";
            return;
        }

        isSavingConn = true;
        try
        {
            await BackendApiClient.CreateTenantSnelStartConnectionAsync(TenantId, createConn);
            connSuccess = "Verbinding aangemaakt.";
            createConn = new();
            await LoadAsync();
        }
        catch (Exception ex)
        {
            connError = $"Aanmaken mislukt: {ex.Message}";
        }
        finally { isSavingConn = false; }
    }

    private async Task SaveConnectionAsync()
    {
        connError = null;
        connSuccess = null;

        if (connection is null) return;

        isSavingConn = true;
        try
        {
            var request = new UpdateTenantSnelStartConnectionRequestViewModel
            {
                ConnectionType  = connection.ConnectionType,
                AuthUrl         = connection.AuthUrl.Trim(),
                ApiBaseUrl      = connection.ApiBaseUrl.Trim(),
                SubscriptionKey = string.IsNullOrWhiteSpace(connSubscriptionKey) ? null : connSubscriptionKey.Trim(),
                IsActive        = connection.IsActive
            };

            await BackendApiClient.UpdateTenantSnelStartConnectionAsync(TenantId, connection.Id, request);
            connSuccess = "Verbinding opgeslagen.";
            await LoadAsync();
        }
        catch (Exception ex)
        {
            connError = $"Opslaan mislukt: {ex.Message}";
        }
        finally { isSavingConn = false; }
    }

    // ── Sectie 2 ──────────────────────────────────────────────────────────

    private void ToggleNewAdmin()
    {
        showNewAdmin = !showNewAdmin;
        if (showNewAdmin)
        {
            newAdmin = new CreateSnelStartAdministrationRequestViewModel { TenantId = TenantId };
            adminSuccess = null;
            adminError = null;
        }
    }

    private async Task CreateAdminAsync()
    {
        adminError = null;
        adminSuccess = null;

        if (string.IsNullOrWhiteSpace(newAdmin.Name))
        {
            adminError = "Naam is verplicht.";
            return;
        }

        if (string.IsNullOrWhiteSpace(newAdmin.AdministrationClientKey))
        {
            adminError = "Client Key is verplicht bij aanmaken.";
            return;
        }

        isSavingAdmin = true;
        try
        {
            newAdmin.TenantId = TenantId;
            await BackendApiClient.CreateSnelStartAdministrationAsync(newAdmin);
            adminSuccess = $"Administratie '{newAdmin.Name}' aangemaakt.";
            showNewAdmin = false;
            await LoadAsync();
        }
        catch (Exception ex)
        {
            adminError = $"Aanmaken mislukt: {ex.Message}";
        }
        finally { isSavingAdmin = false; }
    }

    private void StartEditAdmin(SnelStartAdministrationViewModel admin)
    {
        editingAdminId = admin.Id;
        editAdmin = new UpdateSnelStartAdministrationRequestViewModel
        {
            Id                          = admin.Id,
            TenantId                    = TenantId,
            Name                        = admin.Name,
            NameSnelStartAdministration = admin.NameSnelStartAdministration,
            IsActive                    = admin.IsActive
        };
        editAdminClientKey = null;
        adminSuccess = null;
        adminError = null;
    }

    private void CancelEditAdmin()
    {
        editingAdminId = null;
        editAdmin = null;
        editAdminClientKey = null;
    }

    private async Task SaveAdminAsync(Guid adminId)
    {
        if (editAdmin is null) return;

        adminError = null;
        adminSuccess = null;

        if (string.IsNullOrWhiteSpace(editAdmin.Name))
        {
            adminError = "Naam is verplicht.";
            return;
        }

        editAdmin.AdministrationClientKey = string.IsNullOrWhiteSpace(editAdminClientKey)
            ? null
            : editAdminClientKey.Trim();

        isSavingAdmin = true;
        try
        {
            await BackendApiClient.UpdateSnelStartAdministrationAsync(adminId, editAdmin);
            adminSuccess = "Administratie opgeslagen.";
            CancelEditAdmin();
            await LoadAsync();
        }
        catch (Exception ex)
        {
            adminError = $"Opslaan mislukt: {ex.Message}";
        }
        finally { isSavingAdmin = false; }
    }

    // ── Sectie 3 ──────────────────────────────────────────────────────────

    private void OnAdminChanged(BankAccountRow row, ChangeEventArgs e)
    {
        row.PendingAdminId = Guid.TryParse(e.Value?.ToString(), out var g) ? g : null;
    }

    private void OnFormatChanged(BankAccountRow row, ChangeEventArgs e)
    {
        row.PendingFormat = e.Value?.ToString() ?? "Mt940";
    }

    private void OnAutoSyncChanged(BankAccountRow row, ChangeEventArgs e)
    {
        row.PendingAutoSync = e.Value is bool b ? b : bool.TryParse(e.Value?.ToString(), out var bv) && bv;
    }

    private void OnIntervalChanged(BankAccountRow row, ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var v) && v >= 1)
            row.PendingInterval = v;
    }

    private async Task SaveLinkAsync(BankAccountRow row)
    {
        linkError = null;
        linkSuccess = null;

        row.IsSaving = true;
        try
        {
            if (row.Link is null)
            {
                if (row.PendingAdminId is null)
                {
                    linkError = $"Kies een administratie voor {row.BankAccount.AccountName}.";
                    return;
                }

                var request = new CreateBankAccountSnelStartLinkRequestViewModel
                {
                    BankAccountId            = row.BankAccount.Id,
                    SnelStartAdministrationId = row.PendingAdminId.Value,
                    ExportFormat             = row.PendingFormat,
                    IsActive                 = true,
                    AutoSyncEnabled          = row.PendingAutoSync,
                    SyncIntervalMinutes      = row.PendingInterval
                };

                await BackendApiClient.CreateBankAccountSnelStartLinkAsync(request);
                linkSuccess = $"Koppeling aangemaakt voor {row.BankAccount.AccountName}.";
            }
            else
            {
                var request = new UpdateBankAccountSnelStartLinkRequestViewModel
                {
                    Id                       = row.Link.Id,
                    BankAccountId            = row.BankAccount.Id,
                    SnelStartAdministrationId = row.PendingAdminId ?? row.Link.SnelStartAdministrationId,
                    ExportFormat             = row.PendingFormat,
                    IsActive                 = row.Link.IsActive,
                    AutoSyncEnabled          = row.PendingAutoSync,
                    SyncIntervalMinutes      = row.PendingInterval
                };

                await BackendApiClient.UpdateBankAccountSnelStartLinkAsync(row.Link.Id, request);
                linkSuccess = $"Koppeling bijgewerkt voor {row.BankAccount.AccountName}.";
            }

            await LoadAsync();
        }
        catch (Exception ex)
        {
            linkError = $"Opslaan mislukt voor {row.BankAccount.AccountName}: {ex.Message}";
        }
        finally
        {
            row.IsSaving = false;
        }
    }

    private static string FormatGuid(Guid? value) =>
        value.HasValue && value.Value != Guid.Empty ? value.Value.ToString() : string.Empty;

    private sealed class BankAccountRow
    {
        public BankAccountViewModel BankAccount { get; set; } = null!;
        public BankAccountSnelStartLinkViewModel? Link { get; set; }

        public Guid? PendingAdminId { get; set; }
        public string PendingFormat { get; set; } = "Mt940";
        public bool PendingAutoSync { get; set; } = true;
        public int PendingInterval { get; set; } = 15;
        public bool IsSaving { get; set; }
    }
}
