@page "/"

<PageTitle>GoDutch SnelStart Portal</PageTitle>

<h1 class="mb-1">GoDutch SnelStart Portal</h1>
<p class="text-muted mb-4">
    Beheer koppelingen, controleer synchronisaties en begeleid klanten stap voor stap door de onboarding.
</p>

<div class="row g-4 mb-4">
    <div class="col-md-4">
        <div class="card h-100">
            <div class="card-body">
                <h5 class="card-title">Onboarding</h5>
                <p class="card-text text-muted">
                    Begeleid nieuwe klanten bij het invoeren van instellingen en het testen van koppelingen.
                </p>
                <a class="btn btn-outline-primary btn-sm" href="/tenants/onboard">Klant aanmelden</a>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card h-100">
            <div class="card-body">
                <h5 class="card-title">GoDutch synchronisatie</h5>
                <p class="card-text text-muted">
                    Bekijk per bankrekening de laatste synchronisatiestatus en pas auto-sync instellingen aan.
                </p>
                <a class="btn btn-outline-primary btn-sm" href="/godutch/sync">Sync & instellingen</a>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card h-100">
            <div class="card-body">
                <h5 class="card-title">myPOS transactietypes</h5>
                <p class="card-text text-muted">
                    Controleer of alle transactietypes gekoppeld zijn aan een SnelStart grootboekrekening.
                </p>
                <a class="btn btn-outline-primary btn-sm" href="/mypos/type-status">Status bekijken</a>
            </div>
        </div>
    </div>
</div>
