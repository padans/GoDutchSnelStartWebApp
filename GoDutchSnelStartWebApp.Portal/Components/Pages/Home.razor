@page "/"
@using GoDutchSnelStartWebApp.Portal.Services
@inject AppSession Session

<PageTitle>GoDutch SnelStart Portal</PageTitle>

<h1 class="mb-1">GoDutch SnelStart Portal</h1>
<p class="text-muted mb-4">
    Automatisch banktransacties en betaalterminaltransacties verwerken naar SnelStart — per klant, per koppeling.
</p>

<div class="row g-4 mb-5">

    @if (Session.Module == "GoDutch" || Session.Module == "Beheerder")
    {
        <div class="col-12">
            <div class="card h-100 border-0 shadow-sm">
                <div class="card-header fw-bold" style="background:#0066CC; color:#fff;">
                    <span class="me-2">🏦</span> GoDutch → SnelStart
                </div>
                <div class="card-body">
                    <p class="text-muted small mb-3">
                        Banktransacties vanuit het GoDutch-betaalplatform worden automatisch opgehaald en als bankafschrift geïmporteerd in SnelStart.
                    </p>
                    <ul class="list-unstyled feature-list">
                        <li><span class="badge bg-success me-2">✓</span> Transacties ophalen per bankrekening (IBAN) en datumperiode</li>
                        <li><span class="badge bg-success me-2">✓</span> Export naar SnelStart in <strong>MT940</strong> of <strong>CAMT053</strong> formaat</li>
                        <li><span class="badge bg-success me-2">✓</span> Automatische berekening van openings- en eindsaldo per exportperiode</li>
                        <li><span class="badge bg-success me-2">✓</span> Auto-sync via achtergrondworker met instelbaar interval per bankrekening</li>
                        <li><span class="badge bg-success me-2">✓</span> Handmatige resync vanaf een zelfgekozen datum</li>
                        <li><span class="badge bg-success me-2">✓</span> Webhook-ontvangst: SnelStart-import getriggerd door GoDutch-events</li>
                        <li><span class="badge bg-success me-2">✓</span> Retry-mechanisme bij tijdelijke SnelStart-uploadfouten (exponential backoff)</li>
                        <li><span class="badge bg-success me-2">✓</span> Elke sync-run vastgelegd met status, triggerobron en statistieken</li>
                        <li><span class="badge bg-success me-2">✓</span> Syncperiode automatisch bepaald op basis van laatste succesvolle run</li>
                        <li><span class="badge bg-success me-2">✓</span> GoDutch-rekeningen opvragen rechtstreeks vanuit de GoDutch API</li>
                    </ul>
                </div>
                <div class="card-footer bg-transparent">
                    <a class="btn btn-sm btn-primary" href="/godutch/sync">Sync &amp; instellingen</a>
                    <a class="btn btn-sm btn-outline-secondary ms-2" href="/bankaccounts">Bankrekeningen</a>
                </div>
            </div>
        </div>
    }

    @if (Session.Module == "MyPos" || Session.Module == "Beheerder")
    {
        <div class="col-12">
            <div class="card h-100 border-0 shadow-sm">
                <div class="card-header fw-bold" style="background:#0066CC; color:#fff;">
                    <span class="me-2">🖥️</span> MyPos → SnelStart
                </div>
                <div class="card-body">
                    <p class="text-muted small mb-3">
                        Transacties vanuit MyPos-betaalterminals worden geïmporteerd en als exportbatch naar SnelStart verzonden.
                    </p>
                    <ul class="list-unstyled feature-list">
                        <li><span class="badge bg-success me-2">✓</span> MyPos transacties importeren per periode</li>
                        <li><span class="badge bg-success me-2">✓</span> Transactietype mappings beheren per tenant</li>
                        <li><span class="badge bg-success me-2">✓</span> Exportbatches aanmaken en naar SnelStart bankboek exporteren</li>
                        <li><span class="badge bg-success me-2">✓</span> Auto-sync via achtergrondworker</li>
                        <li><span class="badge bg-success me-2">✓</span> Transactietype status bewaking</li>
                    </ul>
                </div>
                <div class="card-footer bg-transparent">
                    <a class="btn btn-sm btn-primary" href="/mypos/import">Import</a>
                    <a class="btn btn-sm btn-outline-secondary ms-2" href="/mypos/mappings">Mappings</a>
                </div>
            </div>
        </div>
    }

</div>

<style>
    .feature-list li {
        padding: 5px 0;
        border-bottom: 1px solid #f0f0f0;
        font-size: .9rem;
    }

    .feature-list li:last-child {
        border-bottom: none;
    }
</style>
