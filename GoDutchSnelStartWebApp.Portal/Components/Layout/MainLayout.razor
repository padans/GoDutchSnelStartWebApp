@inherits LayoutComponentBase
@using GoDutchSnelStartWebApp.Portal.Services
@inject AppSession Session
@implements IDisposable

<LoginModal />

@if (Session.IsLoggedIn)
{
    <div class="app-shell">
        <aside class="app-sidebar">
            <NavMenu />
        </aside>

        <main class="app-main">
            <div class="app-topbar">
                <div style="flex:1">
                    <div class="app-topbar-title">Klantportaal</div>
                    <div class="app-topbar-subtitle">Beheer SnelStart, GoDutch en myPOS per tenant</div>
                </div>
                <div class="app-topbar-user">
                    <span>@Session.Username</span>
                    <button class="btn-logout" @onclick="Session.Logout">Uitloggen</button>
                </div>
            </div>

            <section class="app-content">
                @Body
            </section>
        </main>
    </div>
}

@code {
    protected override void OnInitialized()
    {
        Session.OnChange += StateHasChanged;
    }

    public void Dispose()
    {
        Session.OnChange -= StateHasChanged;
    }
}

<div id="blazor-error-ui" data-nosnippet>
    Er is een onverwachte fout opgetreden.
    <a href="." class="reload">Herladen</a>
    <span class="dismiss">🗙</span>
</div>

<style>
    :root {
        --app-blue: #0066CC;
        --app-blue-dark: #0057AD;
        --app-blue-darker: #004A94;
        --app-blue-light: #EAF4FF;
        --app-blue-button: #0B74DE;
        --app-blue-button-hover: #1E88F5;
        --app-border: #D7E7F8;
        --app-page-bg: #F5F9FF;
        --app-text: #111827;
        --app-muted: #6B7280;
    }

    .app-shell {
        min-height: 100vh;
        display: flex;
        gap: 10px;
        padding: 10px 10px 10px 0;
        background: var(--app-blue-darker);
    }

    .app-sidebar {
        width: 280px;
        flex: 0 0 280px;
        background: linear-gradient(180deg, var(--app-blue) 0%, var(--app-blue-dark) 100%);
        color: #ffffff;
        min-height: 100vh;
        position: sticky;
        top: 0;
        align-self: flex-start;
        box-shadow: 4px 0 18px rgba(0, 68, 136, .18);
        border-bottom-left-radius: 16px;
        border-bottom-right-radius: 16px;
    }

    .app-main {
        flex: 1;
        min-width: 0;
    }

    .app-topbar {
        min-height: 86px;
        background: var(--app-blue);
        border-bottom: 1px solid var(--app-blue-dark);
        border-radius: 16px 16px 16px 16px;
        display: flex;
        align-items: center;
        padding: 0 28px;
        box-shadow: 0 2px 12px rgba(0, 68, 136, .15);
        gap: 16px;
    }

    .app-topbar-user {
        display: flex;
        align-items: center;
        gap: 12px;
        color: #DDEEFF;
        font-size: .9rem;
    }

    .btn-logout {
        background: rgba(255,255,255,.15);
        border: 1px solid rgba(255,255,255,.3);
        color: #ffffff;
        border-radius: 8px;
        padding: 6px 14px;
        font-size: .85rem;
        font-weight: 600;
        cursor: pointer;
        transition: background .15s;
    }

    .btn-logout:hover {
        background: rgba(255,255,255,.25);
    }

    .app-topbar-title {
        font-size: 1.25rem;
        font-weight: 700;
        line-height: 1.25;
        color: #ffffff;
    }

    .app-topbar-subtitle {
        color: #DDEEFF;
        font-size: .95rem;
        line-height: 1.35;
        margin-top: 2px;
    }

    .app-content {
        padding: 28px;
        background: #ffffff;
        border-radius: 16px;
        min-height: calc(100vh - 86px);
    }

    .app-nav {
        padding: 0 16px 20px 16px;
    }

    .app-brand {
        min-height: 86px;
        display: flex;
        flex-direction: column;
        justify-content: center;
        padding: 0 10px;
        border-bottom: 1px solid rgba(255, 255, 255, .22);
        margin-bottom: 18px;
    }

    .app-brand-title {
        font-weight: 700;
        font-size: 1.25rem;
        line-height: 1.25;
        letter-spacing: .01em;
        color: #ffffff;
    }

    .app-brand-subtitle {
        color: #DDEEFF;
        font-size: .95rem;
        line-height: 1.35;
        margin-top: 2px;
    }

    .app-nav-section {
        margin-bottom: 22px;
    }


    .app-nav-heading {
        color: #DDEEFF;
        font-size: .76rem;
        text-transform: uppercase;
        letter-spacing: .08em;
        font-weight: 700;
        padding: 0 10px 8px 10px;
    }

    .app-nav-heading-dark {
        color: white;
        font-weight: 700;
        letter-spacing: .05em;
    }

    .app-nav-link {
        display: flex;
        align-items: center;
        gap: 10px;
        width: 100%;
        color: #ffffff;
        text-decoration: none;
        border-radius: 10px;
        padding: 11px 13px;
        margin-bottom: 7px;
        font-weight: 600;
        background: var(--app-blue-button);
        border: 1px solid rgba(255, 255, 255, .22);
        box-shadow: 0 2px 6px rgba(0, 46, 92, .16);
        transition: background-color .15s ease, color .15s ease, transform .15s ease, box-shadow .15s ease;
    }

        .app-nav-link:hover {
            background: var(--app-blue-button-hover);
            color: #ffffff;
            transform: translateX(2px);
            box-shadow: 0 3px 9px rgba(0, 46, 92, .22);
        }

        .app-nav-link.active {
            background: #ffffff;
            color: var(--app-blue-darker);
            border-color: #ffffff;
            box-shadow: 0 3px 10px rgba(0, 46, 92, .24);
        }

            .app-nav-link.active:hover {
                background: var(--app-blue-light);
                color: var(--app-blue-darker);
            }

    .app-nav-link-icon {
        width: 22px;
        min-width: 22px;
        text-align: center;
        font-size: 1rem;
        line-height: 1;
    }

    .app-nav-note {
        color: #DDEEFF;
        font-size: .8rem;
        line-height: 1.35;
        padding: 6px 10px 0 10px;
    }

    @@media (max-width: 900px) {
        .app-shell {
            display: block;
        }

        .app-sidebar {
            width: 100%;
            min-height: auto;
            position: static;
            box-shadow: none;
        }

        .app-topbar {
            padding: 16px 18px;
        }

        .app-content {
            padding: 18px;
        }
    }
</style>
